{
  "version": 1,
  "name": "Design",
  "model": {
    "default": "{{AGENT_MODEL}}",
    "thinking": "adaptive"
  },
  "apiKeys": {
    "anthropic": "{{ANTHROPIC_API_KEY}}",
    "openai": "{{OPENAI_API_KEY}}",
    "deepseek": "{{DEEPSEEK_API_KEY}}"
  },
  "memory": {
    "enabled": true,
    "provider": "local",
    "embedding": {
      "provider": "{{EMBEDDING_PROVIDER}}",
      "model": "{{EMBEDDING_MODEL}}"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true,
        "config": {
          "botToken": "{{DESIGN_TELEGRAM_BOT_TOKEN}}"
        }
      }
    }
  },
  "agents": {
    "remoteAgents": {
      "orchestrator": {
        "sessionKey": "agent:orchestrator:main",
        "description": "Boss — route, escalation, and final delivery"
      },
      "content": {
        "sessionKey": "agent:content:main",
        "description": "Copy alignment and product framing"
      }
    }
  },
  "workspace": {
    "path": "{{WORKSPACE_PATH}}/design"
  },
  "heartbeat": {
    "enabled": true,
    "intervalMinutes": 30
  },
  "exec": {
    "defaultTimeoutSeconds": 30
  }
}
