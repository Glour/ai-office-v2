{
  "version": 1,
  "name": "Content",
  "model": {
    "default": "{{AGENT_MODEL}}",
    "thinking": "adaptive"
  },
  "apiKeys": {
    "anthropic": "{{ANTHROPIC_API_KEY}}",
    "openai": "{{OPENAI_API_KEY}}",
    "deepseek": "{{DEEPSEEK_API_KEY}}"
  },
  "memory": {
    "enabled": true,
    "provider": "local",
    "embedding": {
      "provider": "{{EMBEDDING_PROVIDER}}",
      "model": "{{EMBEDDING_MODEL}}"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true,
        "config": {
          "botToken": "{{CONTENT_TELEGRAM_BOT_TOKEN}}",
          "authorizedSenders": ["{{OWNER_TELEGRAM_ID}}"]
        }
      }
    }
  },
  "agents": {
    "remoteAgents": {
      "orchestrator": {
        "sessionKey": "agent:orchestrator:main",
        "description": "Boss — route, escalation, and final delivery"
      },
      "research": {
        "sessionKey": "agent:research:main",
        "description": "Fact-checking and references"
      }
    }
  },
  "workspace": {
    "path": "{{WORKSPACE_PATH}}/content"
  },
  "heartbeat": {
    "enabled": true,
    "intervalMinutes": 30
  },
  "exec": {
    "defaultTimeoutSeconds": 30
  }
}
