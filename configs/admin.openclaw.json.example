{
  "version": 1,
  "name": "Admin",
  "model": {
    "default": "{{AGENT_MODEL}}"
  },
  "thinkingDefault": "{{THINKING_DEFAULT}}",
  "reasoningDefault": "{{REASONING_DEFAULT}}",
  "apiKeys": {
    "openai": "{{OPENAI_API_KEY}}",
    "deepseek": "{{DEEPSEEK_API_KEY}}"
  },
  "memory": {
    "enabled": true,
    "provider": "local",
    "embedding": {
      "provider": "{{EMBEDDING_PROVIDER}}",
      "model": "{{EMBEDDING_MODEL}}"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true,
        "config": {
          "botToken": "{{ADMIN_TELEGRAM_BOT_TOKEN}}"
        }
      }
    }
  },
  "agents": {
    "remoteAgents": {
      "orchestrator": {
        "sessionKey": "agent:orchestrator:main",
        "description": "User-facing owner and escalations"
      },
      "producer": {
        "sessionKey": "agent:producer:main",
        "description": "Coordination owner for board, sequencing, and handoff"
      },
      "tester": {
        "sessionKey": "agent:tester:main",
        "description": "QA and security gate for audit evidence"
      },
      "backend": {
        "sessionKey": "agent:backend:main",
        "description": "Technical inputs for infra and system-facing admin work"
      },
      "content": {
        "sessionKey": "agent:content:main",
        "description": "Wording, documents, and report packaging"
      },
      "research": {
        "sessionKey": "agent:research:main",
        "description": "Facts, market context, and external source checks"
      }
    }
  },
  "workspace": {
    "path": "{{WORKSPACE_PATH}}/admin"
  },
  "heartbeat": {
    "enabled": true,
    "intervalMinutes": 30
  },
  "exec": {
    "defaultTimeoutSeconds": 30
  }
}
