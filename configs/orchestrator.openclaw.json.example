{
  "version": 1,
  "name": "Orchestrator",
  "model": {
    "default": "{{MAIN_MODEL}}"
  },
  "thinkingDefault": "{{THINKING_DEFAULT}}",
  "reasoningDefault": "{{REASONING_DEFAULT}}",
  "apiKeys": {
    "openai": "{{OPENAI_API_KEY}}",
    "deepseek": "{{DEEPSEEK_API_KEY}}"
  },
  "memory": {
    "enabled": true,
    "provider": "local",
    "embedding": {
      "provider": "{{EMBEDDING_PROVIDER}}",
      "model": "{{EMBEDDING_MODEL}}"
    }
  },
  "plugins": {
    "entries": {
      "telegram": {
        "enabled": true,
        "config": {
          "botToken": "{{ORCHESTRATOR_TELEGRAM_BOT_TOKEN}}"
        }
      }
    }
  },
  "agents": {
    "remoteAgents": {
      "producer": {
        "sessionKey": "agent:producer:main",
        "description": "Internal producer for board, briefing, decomposition, and cross-agent sequencing"
      },
      "frontend": {
        "sessionKey": "agent:frontend:main",
        "description": "Frontend developer for UI and interaction implementation"
      },
      "backend": {
        "sessionKey": "agent:backend:main",
        "description": "Backend engineer for APIs, data model, and integrations"
      },
      "tester": {
        "sessionKey": "agent:tester:main",
        "description": "QA and security gate for repro, smoke tests, acceptance, and security checks"
      },
      "design": {
        "sessionKey": "agent:design:main",
        "description": "Designer for layout, UX, prototypes, and visual direction"
      },
      "content": {
        "sessionKey": "agent:content:main",
        "description": "Content planning, text creation, messaging, documentation"
      },
      "media": {
        "sessionKey": "agent:media:main",
        "description": "Media creator for photos, video plans, and visual packages"
      },
      "research": {
        "sessionKey": "agent:research:main",
        "description": "Research and competitive analysis"
      },
      "admin": {
        "sessionKey": "agent:admin:main",
        "description": "Admin and finance operations for trackers, reports, budgets, and documents"
      }
    }
  },
  "workspace": {
    "path": "{{WORKSPACE_PATH}}/orchestrator"
  },
  "heartbeat": {
    "enabled": true,
    "intervalMinutes": 30
  },
  "exec": {
    "defaultTimeoutSeconds": 30
  }
}
