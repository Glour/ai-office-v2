# ============================================
# Personal AI Team - Environment Configuration
# ============================================
# Copy this file to .env and fill in your values
# Replace all {{PLACEHOLDER}} with actual data

# --- LLM Provider ---
# Uncomment YOUR provider:
ANTHROPIC_API_KEY=your-anthropic-key
# OPENAI_API_KEY=your-openai-key
# GOOGLE_API_KEY=your-google-key

# --- Embedding (for vector memory search) ---
# OpenAI recommended. Skip if you don't need semantic search.
# OPENAI_API_KEY=your-openai-key  # (same as above if using OpenAI as LLM)

# --- Models (set by setup wizard) ---
# MAIN_MODEL=anthropic/claude-opus-4-5       # For Orchestrator
# AGENT_MODEL=anthropic/claude-sonnet-4-5    # For other agents
# EMBEDDING_PROVIDER=openai
# EMBEDDING_MODEL=text-embedding-3-small

# --- Telegram (optional) ---
# Manager bot (создает/получает токены остальных агентов)
# MANAGER_BOT_TOKEN=your-manager-bot-token
# MANAGER_BOT_USERNAME=your_manager_bot

# ORCHESTRATOR_TELEGRAM_BOT_TOKEN=your-orchestrator-bot-token
# FRONTEND_TELEGRAM_BOT_TOKEN=your-frontend-bot-token
# BACKEND_TELEGRAM_BOT_TOKEN=your-backend-bot-token
# DESIGN_TELEGRAM_BOT_TOKEN=your-design-bot-token
# CONTENT_TELEGRAM_BOT_TOKEN=your-content-bot-token
# MEDIA_TELEGRAM_BOT_TOKEN=your-media-bot-token
# RESEARCH_TELEGRAM_BOT_TOKEN=your-research-bot-token
# OWNER_TELEGRAM_ID=your-telegram-id
# TEAM_TELEGRAM_GROUP_ID=-1001234567890
# ORCHESTRATOR_TOPIC_ID=1
# FRONTEND_TOPIC_ID=13
# BACKEND_TOPIC_ID=12
# DESIGN_TOPIC_ID=16
# CONTENT_TOPIC_ID=15
# RESEARCH_TOPIC_ID=14

# --- Personal Data ---
# Used in agent configs for personalization
OWNER_NAME=YourName
OWNER_SURNAME=YourSurname
OWNER_USERNAME=your-github-username

# --- Paths ---
# OPENCLAW_DIR=$HOME/.openclaw-personal
# OPENCLAW_AGENTS_DIR=$HOME/openclaw-agents-personal
# WORKSPACE_PATH=$HOME/openclaw-agents-personal
# PROJECTS_PATH=~/projects/
# TEAM_BOT_PREFIX=alex

# --- GitHub (optional) ---
# GITHUB_ORG=your-github-org
# GITHUB_TOKEN=your-github-token

# --- Webhooks (optional) ---
# WEBHOOK_TOKEN=your_webhook_token_here

# --- Notifications (optional) ---
# GROUP_CHAT_ID=your-group-chat-id
# NOTIFY_CHANNEL_ID=your-notify-channel-id
